# Copy to .env and fill in. NEVER commit .env.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role key (Settings -> API). This service WRITES readings/weather
# and bypasses RLS. Keep it server-side only — never ship it to the web app.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAQ v3 API key — https://explore.openaq.org/register
OPENAQ_API_KEY=
